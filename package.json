    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "postcss-nesting": "^14.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  }
